<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center">

    <ImageView
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/ic_emergency"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="QuickCare"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/primary"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/question_urgence"
        android:textSize="18sp"
        android:layout_marginBottom="32dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <Button
            android:id="@+id/btn_accident"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="🚑 Accident"
            android:textSize="18sp"
            android:layout_marginBottom="12dp"
            style="@style/Widget.Material3.Button.Elevated"/>

        <Button
            android:id="@+id/btn_cardiaque"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="❤️ Crise cardiaque"
            android:textSize="18sp"
            android:layout_marginBottom="12dp"
            style="@style/Widget.Material3.Button.Elevated"/>

        <Button
            android:id="@+id/btn_accouchement"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="👶 Urgence accouchement"
            android:textSize="18sp"
            android:layout_marginBottom="12dp"
            style="@style/Widget.Material3.Button.Elevated"/>

        <Button
            android:id="@+id/btn_autre"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="🆘 Autre urgence"
            android:textSize="18sp"
            style="@style/Widget.Material3.Button.Outlined"/>

    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:visibility="gone"/>

</LinearLayout>
